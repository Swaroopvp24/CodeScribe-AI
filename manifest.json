{
  "manifest_version": 3,
  "name": "LeetCode & NeetCode Git Sync",
  "version": "1.2",
  "description": "Saves your coding solutions and personal notes directly to GitHub.",
  "options_page": "options.html",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.leetcode.com/*",
    "https://neetcode.io/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.leetcode.com/*",
        "https://neetcode.io/*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://neetcode.io/*"
      ],
      "js": ["neetcode-inject.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}