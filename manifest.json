{
  "manifest_version": 3,
  "name": "LeetCode & NeetCode Git Sync",
  "version": "1.2",
  "description": "Saves your coding solutions and personal notes directly to GitHub.",
  "permissions": [
    "storage",
    "webRequest"
  ],
  "host_permissions": [
    "https://*.leetcode.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ]
}